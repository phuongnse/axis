{
  "OpenTelemetry": {
    "Enabled": true,
    "DisableInTesting": true,
    "ServiceName": "axis-api",
    "ExportLogs": true,
    "Otlp": {
      "Endpoint": "http://localhost:4318"
    },
    "Prometheus": {
      "Enabled": true,
      "ScrapeEndpointPath": "/metrics"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "ConnectionStrings": {
    "Identity": "Host=localhost;Port=5432;Database=axis_identity;Username=axis;Password=axis_dev_pass"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "change-me-in-production-must-be-at-least-32-chars!!",
    "Issuer": "axis",
    "Audience": "axis",
    "AccessTokenTtlMinutes": 15
  },
  "Email": {
    "Host": "localhost",
    "Port": 1025,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@axis.io",
    "FromName": "Axis Platform"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["https://localhost:5173", "https://localhost:3000"]
  }
}
