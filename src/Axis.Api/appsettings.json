{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "ConnectionStrings": {
    "Identity": "Host=localhost;Port=5432;Database=axis;Username=axis;Password=axis",
    "DataModeling": "Host=localhost;Port=5432;Database=axis;Username=axis;Password=axis",
    "WorkflowBuilder": "Host=localhost;Port=5432;Database=axis;Username=axis;Password=axis",
    "FormBuilder": "Host=localhost;Port=5432;Database=axis;Username=axis;Password=axis",
    "WorkflowEngine": "Host=localhost;Port=5432;Database=axis;Username=axis;Password=axis",
    "Wolverine": "Host=localhost;Port=5432;Database=axis;Username=axis;Password=axis"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Kafka": {
    "Brokers": "localhost:29092"
  },
  "Jwt": {
    "SecretKey": "change-me-in-production-must-be-at-least-32-chars!!",
    "Issuer": "axis",
    "Audience": "axis",
    "AccessTokenTtlMinutes": 15
  },
  "RefreshToken": {
    "TtlDays": 7
  },
  "Email": {
    "Host": "localhost",
    "Port": 1025,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@axis.io",
    "FromName": "Axis Platform"
  },
  "Aws": {
    "ServiceURL": "http://localhost:4566",
    "S3BucketName": "axis-avatars",
    "Region": "us-east-1"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  }
}
