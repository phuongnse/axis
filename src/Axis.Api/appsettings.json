{
  "OpenTelemetry": {
    "Enabled": true,
    "DisableInTesting": true,
    "ServiceName": "axis-api",
    "ExportLogs": true,
    "Otlp": {
      "Endpoint": "http://localhost:4317",
      "Protocol": "Grpc"
    },
    "Prometheus": {
      "Enabled": true,
      "ScrapeEndpointPath": "/metrics"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "ConnectionStrings": {
    "Identity": "Host=localhost;Port=5432;Database=axis_identity;Username=axis;Password=axis_dev_pass",
    "DataModeling": "Host=localhost;Port=5432;Database=axis_datamodeling;Username=axis;Password=axis_dev_pass",
    "WorkflowBuilder": "Host=localhost;Port=5432;Database=axis_workflowbuilder;Username=axis;Password=axis_dev_pass",
    "FormBuilder": "Host=localhost;Port=5432;Database=axis_formbuilder;Username=axis;Password=axis_dev_pass",
    "WorkflowEngine": "Host=localhost;Port=5432;Database=axis_workflowengine;Username=axis;Password=axis_dev_pass",
    "RabbitMq": "amqp://guest:guest@localhost:5672/"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Modules": {
    "Identity": {
      "GrpcUrl": "http://localhost:5280"
    }
  },
  "Kafka": {
    "Brokers": "localhost:29092"
  },
  "SchemaRegistry": {
    "Url": "http://localhost:8081"
  },
  "Jwt": {
    "SecretKey": "change-me-in-production-must-be-at-least-32-chars!!",
    "Issuer": "axis",
    "Audience": "axis",
    "AccessTokenTtlMinutes": 15
  },
  "RefreshToken": {
    "TtlDays": 7
  },
  "Email": {
    "Host": "localhost",
    "Port": 1025,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@axis.io",
    "FromName": "Axis Platform"
  },
  "Aws": {
    "ServiceURL": "http://localhost:4566",
    "S3BucketName": "axis-avatars",
    "Region": "us-east-1"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  }
}
