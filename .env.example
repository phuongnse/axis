# Optional local Docker Compose overrides.
# Copy to `.env.local` (gitignored). Defaults for the stack are in docker-compose.yml;
# most contributors never need this file.

# Vite bind-mount file watching. Auto-enabled on WSL in frontend/scripts/docker-dev-entrypoint.sh.
# Set 1 if hot reload misses edits (e.g. some Docker Desktop bind mounts); 0 to force off.
# VITE_USE_POLLING=1

# Browser-facing origin used in verification email links. Keep this reachable from the browser
# that opens Maildev messages; do not use internal Compose service names for human local dev.
# APP_BASE_URL=https://localhost:3000

# Local Maildev sender identity. Use a verified owned domain outside local dev.
# EMAIL_FROM_ADDRESS=noreply@axis.localhost
# EMAIL_FROM_NAME=Axis Platform
