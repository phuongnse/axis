# syntax=docker/dockerfile:1.7
FROM node:20-alpine
WORKDIR /app

# Install deps as root, then chown /app so the unprivileged `node` user (uid
# 1000, baked into the image) can write to node_modules and the bind-mounted
# workspace at runtime.
COPY --chown=node:node package.json package-lock.json ./
RUN npm ci && chown -R node:node /app

USER node

EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
