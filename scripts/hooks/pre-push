#!/usr/bin/env bash
# Pre-push gate: runs fast local checks before any push - build, vulnerable
# package scan, format, unit tests, frontend, and doc drift.
#
# CI remains the authoritative full gate and runs the Testcontainers-backed
# Infrastructure/API tests before merge.
#
# Enable once:  git config core.hooksPath scripts/hooks   (or: scripts/install-hooks.sh)
# Emergency escape hatch remains Git's standard:
#   git push --no-verify   (justify it; CI still runs the full gate)
exec "$(git rev-parse --show-toplevel)/scripts/verify.sh"
