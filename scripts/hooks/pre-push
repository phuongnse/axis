#!/usr/bin/env bash
# Pre-push gate: runs the full local mirror of CI before any push — build,
# format, frontend, doc drift AND the Testcontainers integration tests — so no
# backend change reaches a PR without its integration tests having passed
# locally first. Catches the "build passed locally but CI failed" class AND the
# integration-only failures that used to first appear in CI. There is no
# skip-integration mode.
#
# Requires a running Docker daemon when backend files changed (Testcontainers).
# verify.sh fails early with an actionable message if Docker is down.
#
# Enable once:  git config core.hooksPath scripts/hooks   (or: scripts/install-hooks.sh)
# Bypass is reserved for genuine emergencies, never to skip failing tests:
#   git push --no-verify   (justify it; CI still runs the same gate)
exec "$(git rev-parse --show-toplevel)/scripts/verify.sh"
