#!/usr/bin/env bash
# Git hook entrypoint. Python is the source of truth: scripts/axis.py verify.
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if [ -z "${PYTHON:-}" ]; then
  if command -v python3 >/dev/null 2>&1; then
    PYTHON=python3
  elif command -v python >/dev/null 2>&1; then
    PYTHON=python
  else
    echo "Python is required. Set PYTHON or install python/python3 on PATH." >&2
    exit 1
  fi
fi
exec "${PYTHON}" "${ROOT}/scripts/axis.py" verify
