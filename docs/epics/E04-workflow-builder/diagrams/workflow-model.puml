@startuml workflow-model
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Segoe UI
skinparam classAttributeIconSize 0

skinparam class {
    BorderColor #4A90D9
    BackgroundColor #EBF4FF
    FontColor #1A1A2E
    ArrowColor #4A90D9
}

title Workflow Builder — Core Entity Relationships

class WorkflowDefinition {
    +id: UUID
    +name: string
    +slug: string
    +description: string
    +status: WorkflowStatus
    +version: int
    +createdAt: DateTime
    +updatedAt: DateTime
}

enum WorkflowStatus {
    Draft
    Active
    Archived
}

class TriggerConfig {
    +id: UUID
    +workflowId: UUID
    +type: TriggerType
    +config: JSONB
}

enum TriggerType {
    Manual
    Schedule
    Webhook
    Event
}

class StepDefinition {
    +id: UUID
    +workflowId: UUID
    +name: string
    +type: StepType
    +config: JSONB
    +positionX: float
    +positionY: float
    +displayOrder: int
}

enum StepType {
    Form
    HttpRequest
    Condition
    Script
    Notification
}

class Transition {
    +id: UUID
    +workflowId: UUID
    +fromStepId: UUID
    +toStepId: UUID
    +label: string
    +condition: string
    +displayOrder: int
}

class ParallelGroup {
    +id: UUID
    +workflowId: UUID
    +name: string
    +joinType: JoinType
}

enum JoinType {
    WaitAll
    WaitAny
}

WorkflowDefinition --> WorkflowStatus
WorkflowDefinition "1" *-- "1" TriggerConfig : has
WorkflowDefinition "1" *-- "many" StepDefinition : contains
WorkflowDefinition "1" *-- "many" Transition : contains
StepDefinition --> StepType
TriggerConfig --> TriggerType
Transition --> StepDefinition : fromStep
Transition --> StepDefinition : toStep
StepDefinition "many" ..> "0..1" ParallelGroup : belongs to
ParallelGroup --> JoinType

note right of StepDefinition
  config: JSONB contains type-specific settings
  Form step: { formId, assigneeExpr, timeout }
  HTTP step: { method, url, headers, body, auth }
  Condition: { branches: [{label, expression}] }
  Script: { script, timeout }
  Notification: { channel, recipient, template }
end note

@enduml
