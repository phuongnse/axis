@startuml execution-flow
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Segoe UI
skinparam sequenceMessageAlign center
skinparam sequence {
    ArrowColor #4A90D9
    ActorBorderColor #4A90D9
    LifeLineBorderColor #4A90D9
    ParticipantBorderColor #4A90D9
    ParticipantBackgroundColor #EBF4FF
}

title Workflow Execution Flow

participant "Trigger\n(Manual/Schedule/\nWebhook/Event)" as Trigger
participant "Execution\nOrchestrator" as Engine
participant "Step Handler\n(per type)" as Handler
participant "Wolverine\n(Job Runner)" as Jobs
database "PostgreSQL" as DB
participant "SignalR Hub" as SignalR
actor "User Browser" as Browser

== Execution Start ==

Trigger -> Engine: Start execution\n(workflowId, inputPayload)
Engine -> DB: Create Execution record\n(status: PENDING)
Engine -> DB: Create StepExecution records\n(all steps, status: PENDING)
Engine -> Jobs: Enqueue ExecuteNextStep(executionId)
Engine -> SignalR: Publish ExecutionStarted event
SignalR -> Browser: Push status update

== Step Execution Loop ==

loop For each step (in order)
    Jobs -> Engine: ExecuteNextStep(executionId)
    Engine -> DB: Update current step\n(status: RUNNING)
    Engine -> SignalR: Publish StepStarted event
    SignalR -> Browser: Push status update

    Engine -> Handler: Execute(stepDefinition, context)

    alt Form Step
        Handler -> DB: Create FormTask (status: PENDING)
        Handler -> Jobs: Send form notification
        note over Handler: Step stays WAITING\nuntil form submitted
    else HTTP / Condition / Script / Notification Step
        Handler -> Handler: Execute step logic
        Handler --> Engine: StepResult(success, output)
    end

    alt Step succeeded
        Engine -> DB: Update step\n(status: COMPLETED, output)
        Engine -> DB: Merge output into execution context
        Engine -> Jobs: Enqueue ExecuteNextStep
        Engine -> SignalR: Publish StepCompleted event
        SignalR -> Browser: Push status update
    else Step failed
        Engine -> DB: Update step (status: FAILED, error)
        Engine -> DB: Update execution (status: FAILED)
        Engine -> Jobs: Send error notification
        Engine -> SignalR: Publish ExecutionFailed event
        SignalR -> Browser: Push status update
        note over Engine: Execution halts;\nuser must retry manually
    end
end

== Execution Complete ==

Engine -> DB: Update execution (status: COMPLETED)
Engine -> SignalR: Publish ExecutionCompleted event
SignalR -> Browser: Push status update

@enduml
