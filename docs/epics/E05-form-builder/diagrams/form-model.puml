@startuml form-model
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Segoe UI
skinparam classAttributeIconSize 0

skinparam class {
    BorderColor #4A90D9
    BackgroundColor #EBF4FF
    FontColor #1A1A2E
    ArrowColor #4A90D9
}

title Form Builder — Core Entity Relationships

class FormDefinition {
    +id: UUID
    +name: string
    +description: string
    +createdAt: DateTime
    +updatedAt: DateTime
}

class FormSection {
    +id: UUID
    +formId: UUID
    +title: string
    +description: string
    +displayOrder: int
}

class FormFieldDefinition {
    +id: UUID
    +formId: UUID
    +sectionId: UUID?
    +name: string
    +label: string
    +type: FormFieldType
    +required: boolean
    +helpText: string
    +displayOrder: int
    +validationConfig: JSONB
    +defaultValueExpr: string
}

enum FormFieldType {
    TextInput
    Textarea
    Number
    DatePicker
    Dropdown
    MultiSelect
    Checkbox
    FileUpload
    RelationPicker
}

class FormTask {
    +id: UUID
    +formId: UUID
    +executionId: UUID
    +stepId: UUID
    +assigneeId: UUID
    +status: FormTaskStatus
    +token: string
    +expiresAt: DateTime
    +createdAt: DateTime
}

enum FormTaskStatus {
    Pending
    Completed
    Expired
    Cancelled
}

class FormSubmission {
    +id: UUID
    +formTaskId: UUID
    +submittedBy: UUID
    +submittedAt: DateTime
    +data: JSONB
}

FormDefinition "1" *-- "many" FormSection : has
FormDefinition "1" *-- "many" FormFieldDefinition : has
FormSection "1" o-- "many" FormFieldDefinition : groups
FormFieldDefinition --> FormFieldType
FormDefinition "1" --> "many" FormTask : generates at runtime
FormTask --> FormTaskStatus
FormTask "1" -- "1" FormSubmission : results in

note bottom of FormSubmission
  data: JSONB stores all submitted values
  Example:
  {
    "applicant_name": "John Doe",
    "start_date": "2026-06-01",
    "approved": true,
    "resume": "file-ref-uuid"
  }
end note

@enduml
