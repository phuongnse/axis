@startuml system-context
!include <C4/C4_Context>

LAYOUT_WITH_LEGEND()

title System Context — Axis Platform

Person(platformAdmin, "Platform Admin", "Axis internal team.\nManages tenants and platform health.")
Person(orgAdmin, "Organization Admin", "Tenant admin.\nConfigures org, builds workflows and models.")
Person(orgMember, "Organization Member", "Tenant user.\nExecutes workflows and manages data.")
Person(endUser, "End User", "External stakeholder.\nSubmits forms and views published pages.")

System(axis, "Axis Platform", "Multi-tenant low-code SaaS.\nWorkflow automation, data modeling,\nform builder, and UI builder.")

System_Ext(emailService, "Email Service", "Sends transactional emails:\ninvitations, form tasks, error alerts.")
System_Ext(externalApis, "External APIs", "Third-party REST APIs called\nby HTTP Request workflow steps.")
System_Ext(webhookTargets, "Webhook Targets", "External systems that receive\nwebhook notifications from workflows.")

Rel(platformAdmin, axis, "Manages platform,\nmonitors tenants", "HTTPS")
Rel(orgAdmin, axis, "Configures org, builds\nworkflows and models", "HTTPS")
Rel(orgMember, axis, "Executes workflows,\nmanages records", "HTTPS")
Rel(endUser, axis, "Submits forms,\nviews pages", "HTTPS")

Rel(axis, emailService, "Sends emails", "SMTP / API")
Rel(axis, externalApis, "HTTP Request steps", "HTTPS")
Rel(axis, webhookTargets, "Webhook notifications", "HTTPS")

@enduml
